{
  "name": "ai-by",
  "version": "0.2.5",
  "description": "AI By - production-grade plugin-based coding agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "ai-coder": "./dist/cli.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "homepage": "https://github.com/simpletoolsindia/ai-coder",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simpletoolsindia/ai-coder.git"
  },
  "bugs": {
    "url": "https://github.com/simpletoolsindia/ai-coder/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "install.sh",
    "install.ps1"
  ],
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "llm",
    "openai",
    "anthropic",
    "cli",
    "mcp",
    "plugins"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:perf": "vitest run tests/perf",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start": "node --enable-source-maps dist/cli.js",
    "dev": "tsx src/cli.ts",
    "validate:manifests": "tsx scripts/validate-manifests.ts",
    "publish:npm": "npm run build && npm publish --access public",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "glob": "^11.0.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.31",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
